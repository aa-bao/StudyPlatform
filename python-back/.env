# ========== GLM API 配置 ==========
GLM_API_KEY=your_glm_api_key_here

# ========== 模型配置 ==========
# 图片识别模型（GLM-4V-Flash - 更快、更便宜）
GLM_MODEL_IMAGE=glm-4v-flash

# 智能批改模型（GLM-4-Plus - 更智能、更准确）
GLM_MODEL_GRADING=glm-4-plus

# ========== 服务配置 ==========
APP_PORT=8082
APP_HOST=0.0.0.0

# ========== CORS 配置 ==========
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# ========== 日志配置 ==========
LOG_LEVEL=INFO
